# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer le fichier .env

# Serveur
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Session
SESSION_SECRET=changez-cette-valeur-en-production
SESSION_DIR=./database/sessions
COOKIE_SAMESITE=lax

# Base de données
DB_PATH=./database/recette_avis.sqlite

# Railway avec Volume monte sur /app/database :
# NODE_ENV=production
# DB_PATH=/app/database/recette_avis.sqlite
# SESSION_DIR=/app/database/sessions
