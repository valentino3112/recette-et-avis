# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer le fichier .env

# Serveur
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
# En dev seulement (front Vite sur :3000, back Express sur :3001)
FRONTEND_URL=http://localhost:3000

# Session
SESSION_SECRET=changez-cette-valeur-en-production
SESSION_DIR=./database/sessions
COOKIE_SAMESITE=lax

# Base de données
DB_PATH=./database/recette_avis.sqlite

# ── Railway avec Volume monté sur /app/database ──────────────────────────────
# NODE_ENV=production
# SESSION_SECRET=<valeur longue et aléatoire>
# DB_PATH=/app/database/recette_avis.sqlite
# SESSION_DIR=/app/database/sessions
# COOKIE_SAMESITE=lax
# (FRONTEND_URL n'est pas nécessaire en production : front et back sur le même hôte)
