{
  "name": "recette-et-avis",
  "version": "1.0.0",
  "description": "Plateforme communautaire de recettes et d'avis — EFREI TI616",
  "main": "backend/server.js",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "start": "node --experimental-sqlite database/seed.js --if-empty && node --experimental-sqlite backend/server.js",
    "start:server": "node --experimental-sqlite backend/server.js",
    "dev":   "nodemon backend/server.js",
    "db:init": "node --experimental-sqlite database/seed.js",
    "db:init-if-empty": "node --experimental-sqlite database/seed.js --if-empty",
    "test": "jest --runInBand --forceExit",
    "convert-images": "node tools/convert-images.js"
  },
  "nodemonConfig": {
    "nodeArgs": ["--experimental-sqlite"]
  },
  "dependencies": {
    "bcryptjs":          "^2.4.3",
    "cors":              "^2.8.5",
    "dotenv":            "^16.4.5",
    "express":           "^4.18.3",
    "express-session":   "^1.18.0",
    "express-validator": "^7.0.1",
    "session-file-store":"^1.5.0"
  },
  "devDependencies": {
    "jest":     "^29.7.0",
    "nodemon":  "^3.1.0",
    "supertest":"^7.0.0",
    "sharp": "^0.32.0"
  }

}
