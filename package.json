{
  "name": "recette-et-avis",
  "version": "1.0.0",
  "description": "Plateforme communautaire de recettes et d'avis — EFREI TI616",
  "main": "backend/server.js",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build":            "vite build",
    "preview":          "vite preview",
    "dev:frontend":     "vite",
    "dev:backend":      "nodemon backend/server.js",
    "dev":              "node --experimental-sqlite database/seed.js --if-empty && nodemon backend/server.js",
    "start":            "node --experimental-sqlite database/seed.js --if-empty && node --experimental-sqlite backend/server.js",
    "db:init":          "node --experimental-sqlite database/seed.js",
    "db:init-if-empty": "node --experimental-sqlite database/seed.js --if-empty",
    "test":             "jest --runInBand --forceExit"
  },
  "nodemonConfig": {
    "nodeArgs": ["--experimental-sqlite"]
  },
  "dependencies": {
    "bcryptjs":          "^2.4.3",
    "cors":              "^2.8.5",
    "dotenv":            "^16.4.5",
    "express":           "^4.18.3",
    "express-session":   "^1.18.0",
    "express-validator": "^7.0.1",
    "session-file-store":"^1.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "jest":                 "^29.7.0",
    "nodemon":              "^3.1.0",
    "react":                "^18.3.1",
    "react-dom":            "^18.3.1",
    "supertest":            "^7.0.0",
    "vite":                 "^5.4.11"
  }
}
